@page "/"
@using TheR7angelo.github.io.Resources.Resx.HomePage

<PageTitle>TheR7angelo @HomePageResources.NavBarTitle</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="my-8">
    @foreach (var item in MainLayout.Sections)
    {
        <MudPaper Outlined="true" Elevation="0" Class="py-6 px-4 mb-6" id="@item.Id">
            <DynamicComponent Type="@item.ComponentType" />
        </MudPaper>
    }
</MudContainer>