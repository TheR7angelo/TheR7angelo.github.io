<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5">Projets réalisés avec @TechName</MudText>
    </TitleContent>

    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-4">
            Voici les projets majeurs où j'ai conçu et exploité la base de données <strong>@TechName</strong> :
        </MudText>

        @foreach (var project in Projects)
        {
            <MudText Typo="Typo.h6" Color="Color.Primary">@project.IconAndTitle</MudText>
            <MudText Typo="Typo.body2" Class="mb-3" Style="white-space: pre-line;">@project.Description</MudText>
        }

    </DialogContent>

    <DialogActions>
        @* TODO trad *@
        <MudButton Color="Color.Primary" OnClick="@Close">Fermer</MudButton>
    </DialogActions>

</MudDialog>